<Window x:Class="SpotifyLyricsTaskbar.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sonar" Width="1000" Height="672"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen" ShowInTaskbar="True"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <!-- Darker device palette; "Mint" is now a frosted/glassy white used for selections. -->
        <SolidColorBrush x:Key="Panel" Color="#0C0D0F"/>
        <SolidColorBrush x:Key="Sub"   Color="#16171A"/>
        <SolidColorBrush x:Key="Sub2"  Color="#1D1F23"/>
        <SolidColorBrush x:Key="Stroke" Color="#292B30"/>
        <SolidColorBrush x:Key="Text"  Color="#F1F1F3"/>
        <SolidColorBrush x:Key="Muted" Color="#83858C"/>
        <SolidColorBrush x:Key="Mint"  Color="#E9EEF1"/>
        <SolidColorBrush x:Key="Glass" Color="#26FFFFFF"/>
        <SolidColorBrush x:Key="Lcd"   Color="#050608"/>

        <Style x:Key="H" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2,0,0,9"/>
        </Style>

        <Style x:Key="Pill" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="11" Background="{StaticResource Sub}"
                                BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="13,9">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Mint}"/></Trigger>
                            <Trigger Property="Tag" Value="on">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Glass}"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Mint}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Transport" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="22" Width="44" Height="44" Background="{StaticResource Sub}" BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Mint}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Ghost" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="6,3"><ContentPresenter VerticalAlignment="Center"/></Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Foreground" Value="{StaticResource Mint}"/></Trigger></Style.Triggers>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource Mint}"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Slider value read-out: same fixed column + left-aligned on every row, so the
             number always sits just right of the track end (one consistent location). -->
        <Style x:Key="RowVal" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="12,0,0,0"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
    <Border x:Name="DeviceRoot" Background="{StaticResource Panel}" CornerRadius="22" BorderBrush="#1E1F23" BorderThickness="1">
        <Grid Margin="24,18,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="38" Height="38" CornerRadius="10" ClipToBounds="True" Background="White">
                        <Image Source="pack://application:,,,/Assets/sonarlogo.png" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="SONAR" Foreground="{StaticResource Text}" FontSize="19" FontWeight="Bold"/>
                        <TextBlock Text="taskbar lyrics" Foreground="{StaticResource Muted}" FontSize="11" Margin="1,-2,0,0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="ResetBtn" Style="{StaticResource Ghost}" Content="↺ Reset"/>
                    <Button x:Name="CloseBtn" Style="{StaticResource Ghost}" Content="✕" FontSize="15" Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Body -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="430"/>
                    <ColumnDefinition Width="26"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: preview + playback + display sliders + timing -->
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource H}" Text="PREVIEW"/>
                    <Border Height="96" CornerRadius="14" Background="{StaticResource Lcd}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border x:Name="PreviewArt" Grid.Column="0" Width="64" Height="64" CornerRadius="8" VerticalAlignment="Center" ClipToBounds="True"/>
                            <Grid Grid.Column="1" Margin="14,0,0,0" ClipToBounds="True">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="PreviewTitle" Foreground="{StaticResource Muted}" FontSize="11" Margin="2,0,0,5"/>
                                    <StackPanel x:Name="PreviewHost" Orientation="Horizontal" Height="30"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <TextBlock Style="{StaticResource H}" Text="PLAYBACK" Margin="2,18,0,9"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="PrevBtn" Style="{StaticResource Transport}" Content="⏮"/>
                        <Button x:Name="PlayBtn" Style="{StaticResource Transport}" Content="▶" Margin="12,0"/>
                        <Button x:Name="NextBtn" Style="{StaticResource Transport}" Content="⏭"/>
                        <TextBlock Text="controls Spotify" Foreground="{StaticResource Muted}" FontSize="11" VerticalAlignment="Center" Margin="18,0,0,0"/>
                    </StackPanel>

                    <TextBlock Style="{StaticResource H}" Text="DISPLAY" Margin="2,20,0,9"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/><ColumnDefinition Width="72"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="Size"/>
                        <Slider Grid.Column="1" x:Name="SizeSlider" Minimum="9" Maximum="24"/>
                        <TextBlock Grid.Column="2" x:Name="SizeVal" Style="{StaticResource RowVal}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/><ColumnDefinition Width="72"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="Glow"/>
                        <Slider Grid.Column="1" x:Name="GlowSlider" Minimum="0" Maximum="40"/>
                        <TextBlock Grid.Column="2" x:Name="GlowVal" Style="{StaticResource RowVal}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/><ColumnDefinition Width="72"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="Opacity"/>
                        <Slider Grid.Column="1" x:Name="OpacitySlider" Minimum="20" Maximum="100"/>
                        <TextBlock Grid.Column="2" x:Name="OpacityVal" Style="{StaticResource RowVal}"/>
                    </Grid>

                    <TextBlock Style="{StaticResource H}" Text="TIMING" Margin="2,18,0,9"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/><ColumnDefinition Width="72"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="Offset"/>
                        <Slider Grid.Column="1" x:Name="OffsetSlider" Minimum="-15000" Maximum="15000"/>
                        <TextBlock Grid.Column="2" x:Name="OffsetVal" Style="{StaticResource RowVal}"/>
                    </Grid>
                    <TextBlock x:Name="OffsetHint" Text="nudges the current song · + = sooner" Foreground="{StaticResource Muted}" FontSize="10" Margin="66,3,0,0"/>

                    <TextBlock Style="{StaticResource H}" Text="APP" Margin="2,18,0,9"/>
                    <WrapPanel x:Name="AppTogglesPanel"/>
                    <TextBlock x:Name="AudioStatus" Foreground="{StaticResource Muted}" FontSize="10" Margin="2,7,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource Stroke}" Margin="13,2"/>

                <!-- RIGHT: font, colour, animation, modes, app -->
                <StackPanel Grid.Column="2" Margin="0,0,2,0">
                    <TextBlock Style="{StaticResource H}" Text="FONT"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
                        <Button x:Name="FontPill" Grid.Column="0" Style="{StaticResource Pill}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="FontName" Text="Poppins" VerticalAlignment="Center"/>
                                <TextBlock Text="  ⌄" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="WeightPill" Grid.Column="2" Style="{StaticResource Pill}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="WeightName" Text="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text="  ⌄" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock Style="{StaticResource H}" Text="COLOUR" Margin="2,18,0,9"/>
                    <WrapPanel x:Name="SwatchPanel"/>

                    <TextBlock Style="{StaticResource H}" Text="ANIMATION" Margin="2,18,0,9"/>
                    <StackPanel x:Name="AnimPanel" Orientation="Horizontal"/>

                    <TextBlock Style="{StaticResource H}" Text="MODES" Margin="2,18,0,9"/>
                    <StackPanel x:Name="ModesPanel"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
    </Grid>
</Window>
